{
  "name": "slideshow-studio",
  "version": "0.2.0",
  "description": "Create looping tribute slideshows from photos with Ken Burns motion, crossfades and blurred backgrounds. Exports MP4/WebM via bundled FFmpeg.",
  "author": "",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "face-api.js": "^0.22.2",
    "ffmpeg-static": "^5.2.0"
  },
  "build": {
    "appId": "com.slideshowstudio.app",
    "productName": "Slideshow Studio",
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.video"
    },
    "directories": {
      "output": "dist"
    }
  }
}
